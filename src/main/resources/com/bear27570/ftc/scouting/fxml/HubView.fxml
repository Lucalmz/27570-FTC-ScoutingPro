<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="650.0" prefWidth="900.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bear27570.ftc.scouting.controllers.HubController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">
            <padding><Insets top="15" right="30" bottom="15" left="30" /></padding>
            <Label fx:id="welcomeLabel" styleClass="title-3" text="Dashboard" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleLogout" text="Logout" styleClass="danger">
                <graphic><FontIcon iconLiteral="fth-log-out" iconSize="14" iconColor="white"/></graphic>
            </Button>
        </HBox>
    </top>
    <center>
        <VBox spacing="35" alignment="TOP_CENTER">
            <padding><Insets top="40" right="40" bottom="40" left="40" /></padding>

            <HBox alignment="CENTER" spacing="25">
                <Button fx:id="hostModeButton" onAction="#selectHostMode" text="Host Competition" prefWidth="200" prefHeight="45">
                    <graphic><FontIcon iconLiteral="fth-server" iconSize="16"/></graphic>
                </Button>
                <Button fx:id="joinModeButton" onAction="#selectJoinMode" text="Join Competition" prefWidth="200" prefHeight="45">
                    <graphic><FontIcon iconLiteral="fth-wifi" iconSize="16"/></graphic>
                </Button>
            </HBox>

            <Label fx:id="statusLabel" styleClass="text-muted" text="Select a mode to begin." />

            <VBox fx:id="hostPane" spacing="20" alignment="TOP_CENTER" managed="false" visible="false" styleClass="mac-card" maxWidth="700">
                <padding><Insets top="30" right="30" bottom="30" left="30" /></padding>
                <Label styleClass="title-4" text="Your Competitions"/>
                <ListView fx:id="myCompetitionsListView" prefHeight="180" styleClass="edge-to-edge"/>

                <HBox spacing="15" alignment="CENTER">
                    <Button onAction="#handleHostButton" text="Start Hosting" styleClass="success" prefWidth="160" prefHeight="38">
                        <graphic><FontIcon iconLiteral="fth-play" iconSize="16" iconColor="white"/></graphic>
                    </Button>
                    <Button onAction="#handleManageMembers" text="Members" styleClass="accent" prefWidth="120" prefHeight="38">
                        <graphic><FontIcon iconLiteral="fth-users" iconSize="14" iconColor="white"/></graphic>
                    </Button>
                    <Button onAction="#handleAllianceAnalysis" text="Analysis" prefWidth="120" prefHeight="38">
                        <graphic><FontIcon iconLiteral="fth-pie-chart" iconSize="14"/></graphic>
                    </Button>
                </HBox>

                <Separator />

                <HBox spacing="15" alignment="CENTER">
                    <TextField fx:id="newCompetitionField" promptText="New Competition Name" prefWidth="300" prefHeight="38"/>
                    <Button onAction="#handleCreateButton" text="Create" styleClass="accent" prefHeight="38">
                        <graphic><FontIcon iconLiteral="fth-plus" iconSize="16" iconColor="white"/></graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox fx:id="joinPane" spacing="20" alignment="TOP_CENTER" managed="false" visible="false" styleClass="mac-card" maxWidth="700">
                <padding><Insets top="30" right="30" bottom="30" left="30" /></padding>
                <Label styleClass="title-4" text="Discovered Competitions"/>
                <ListView fx:id="discoveredCompetitionsListView" prefHeight="220" styleClass="edge-to-edge"/>
                <Button onAction="#handleJoinButton" text="Request to Join" styleClass="accent" prefWidth="240" prefHeight="45">
                    <graphic><FontIcon iconLiteral="fth-send" iconSize="16" iconColor="white"/></graphic>
                </Button>
            </VBox>
        </VBox>
    </center>
</BorderPane>