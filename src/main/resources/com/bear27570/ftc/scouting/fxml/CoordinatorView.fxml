<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="30" alignment="CENTER" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bear27570.ftc.scouting.controllers.CoordinatorController">
    <padding><Insets top="40" right="40" bottom="40" left="40" /></padding>

    <Label styleClass="title-2" text="Manage Competition Members"/>

    <HBox spacing="30" alignment="CENTER">
        <VBox spacing="15" styleClass="mac-card" style="-fx-padding: 25;" HBox.hgrow="ALWAYS">
            <Label text="Pending Applications" styleClass="title-4"/>
            <ListView fx:id="pendingListView" prefHeight="300" prefWidth="260" styleClass="edge-to-edge"/>
        </VBox>

        <VBox spacing="20" alignment="CENTER">
            <Button onAction="#handleApprove" text="Approve" styleClass="success" prefWidth="160" prefHeight="45">
                <graphic><FontIcon iconLiteral="fth-check" iconSize="16" iconColor="white"/></graphic>
            </Button>
            <Button onAction="#handleDeny" text="Deny" styleClass="danger" prefWidth="160" prefHeight="45">
                <graphic><FontIcon iconLiteral="fth-x" iconSize="16" iconColor="white"/></graphic>
            </Button>
            <Region prefHeight="40"/>
            <Button onAction="#handleKick" text="Kick Member" styleClass="warning" prefWidth="160" prefHeight="45">
                <graphic><FontIcon iconLiteral="fth-user-minus" iconSize="16" iconColor="black"/></graphic>
            </Button>
        </VBox>

        <VBox spacing="15" styleClass="mac-card" style="-fx-padding: 25;" HBox.hgrow="ALWAYS">
            <Label text="Approved Members" styleClass="title-4"/>
            <ListView fx:id="approvedListView" prefHeight="300" prefWidth="260" styleClass="edge-to-edge"/>
        </VBox>
    </HBox>

    <Button onAction="#handleClose" text="Done / Close" prefWidth="240" prefHeight="45">
        <graphic><FontIcon iconLiteral="fth-chevron-left" iconSize="16"/></graphic>
    </Button>
</VBox>