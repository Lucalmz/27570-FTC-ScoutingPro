<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bear27570.ftc.scouting.controllers.FieldInputController">
    <center>
        <StackPane fx:id="inputPane" style="-fx-padding: 30;">
            <StackPane styleClass="panel-inner" style="-fx-padding: 0; -fx-background-color: transparent;">
                <ImageView fx:id="fieldImageView" fitHeight="600" fitWidth="600" preserveRatio="true">
                    <image>
                        <Image url="@../images/field.png"/>
                    </image>
                </ImageView>
                <Canvas fx:id="drawCanvas" height="600" width="600" onMouseClicked="#handleCanvasClick"/>
            </StackPane>
        </StackPane>
    </center>
    <right>
        <VBox spacing="25" alignment="TOP_CENTER" prefWidth="240" style="-fx-background-color: -color-bg-overlay; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 0 1px;">
            <padding><Insets top="40" right="25" bottom="40" left="25"/></padding>

            <VBox fx:id="teamSelectBox" spacing="12" alignment="CENTER" styleClass="panel-inner">
                <Label text="Active Team" styleClass="title-4"/>
                <ToggleButton fx:id="team1Btn" text="Team 1" prefWidth="160" prefHeight="38" selected="true" styleClass="accent"/>
                <ToggleButton fx:id="team2Btn" text="Team 2" prefWidth="160" prefHeight="38" styleClass="danger"/>
            </VBox>

            <VBox spacing="12" alignment="CENTER" styleClass="panel-inner">
                <Label text="Input Mode" styleClass="title-4"/>
                <ToggleButton fx:id="addModeBtn" text="Add (+)" prefWidth="160" prefHeight="38" selected="true" styleClass="success"/>
                <ToggleButton fx:id="removeModeBtn" text="Remove (-)" prefWidth="160" prefHeight="38"/>
            </VBox>

            <VBox spacing="5" alignment="CENTER" styleClass="panel-inner">
                <Label text="Total Count" styleClass="text-muted"/>
                <Label fx:id="countLabel" text="0" styleClass="mono-text" style="-fx-font-size: 48px; -fx-font-weight: bold;"/>
                <HBox alignment="CENTER" spacing="20">
                    <HBox alignment="CENTER" spacing="5"><Label text="T1:" style="-fx-text-fill: #0A84FF;"/><Label fx:id="countT1Label" text="0" styleClass="mono-text" style="-fx-text-fill: #0A84FF; -fx-font-weight: bold;"/></HBox>
                    <HBox alignment="CENTER" spacing="5"><Label text="T2:" style="-fx-text-fill: #FF453A;"/><Label fx:id="countT2Label" text="0" styleClass="mono-text" style="-fx-text-fill: #FF453A; -fx-font-weight: bold;"/></HBox>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Button onAction="#handleClear" text="Clear Canvas" styleClass="danger" prefWidth="160" prefHeight="40">
                <graphic><FontIcon iconLiteral="fth-trash-2" iconSize="14" iconColor="white"/></graphic>
            </Button>
            <Button onAction="#handleConfirm" text="Confirm &amp; Save" prefWidth="160" styleClass="success" prefHeight="50">
                <graphic><FontIcon iconLiteral="fth-check-circle" iconSize="16" iconColor="white"/></graphic>
            </Button>
        </VBox>
    </right>
</BorderPane>