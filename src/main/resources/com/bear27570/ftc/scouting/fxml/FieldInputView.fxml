<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bear27570.ftc.scouting.controllers.FieldInputController">
    <center>
        <StackPane fx:id="inputPane" style="-fx-padding: 40;">
            <StackPane styleClass="panel-inner" style="-fx-padding: 0; -fx-background-color: transparent;">
                <ImageView fx:id="fieldImageView" fitHeight="650" fitWidth="650" preserveRatio="true">
                    <image><Image url="@../images/field.png"/></image>
                </ImageView>
                <Canvas fx:id="drawCanvas" height="650" width="650" onMouseClicked="#handleCanvasClick"/>
            </StackPane>
        </StackPane>
    </center>
    <right>
        <VBox spacing="30" alignment="TOP_CENTER" prefWidth="280" style="-fx-background-color: -color-bg-overlay; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 0 1px;">
            <padding><Insets top="50" right="30" bottom="50" left="30"/></padding>

            <VBox fx:id="teamSelectBox" spacing="15" alignment="CENTER" styleClass="panel-inner">
                <Label text="Active Team" styleClass="title-4"/>
                <ToggleButton fx:id="team1Btn" text="Team 1" prefWidth="180" selected="true" styleClass="toggle-green"/>
                <ToggleButton fx:id="team2Btn" text="Team 2" prefWidth="180" styleClass="toggle-green"/>
            </VBox>

            <VBox spacing="15" alignment="CENTER" styleClass="panel-inner">
                <Label text="Input Mode" styleClass="title-4"/>
                <ToggleButton fx:id="addModeBtn" text="Add (+)" prefWidth="180" selected="true" styleClass="toggle-green"/>
                <ToggleButton fx:id="removeModeBtn" text="Remove (-)" prefWidth="180" styleClass="toggle-green"/>
            </VBox>

            <VBox spacing="10" alignment="CENTER" styleClass="panel-inner">
                <Label text="Total Count" styleClass="text-muted"/>
                <Label fx:id="countLabel" text="0" styleClass="mono-text" style="-fx-font-size: 56px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
                <HBox alignment="CENTER" spacing="25">
                    <HBox alignment="CENTER" spacing="5"><Label text="T1:" style="-fx-text-fill: #EAB308;"/><Label fx:id="countT1Label" text="0" styleClass="mono-text" style="-fx-text-fill: #EAB308; -fx-font-weight: bold;"/></HBox>
                    <HBox alignment="CENTER" spacing="5"><Label text="T2:" style="-fx-text-fill: #F87171;"/><Label fx:id="countT2Label" text="0" styleClass="mono-text" style="-fx-text-fill: #F87171; -fx-font-weight: bold;"/></HBox>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Button onAction="#handleUndo" text="Undo (Ctrl+Z)" styleClass="warning" prefWidth="200">
                <graphic><FontIcon iconLiteral="fth-rotate-ccw" iconSize="14" iconColor="#FBBF24"/></graphic>
            </Button>

            <Button onAction="#handleClear" text="Clear Canvas" styleClass="danger" prefWidth="200">
                <graphic><FontIcon iconLiteral="fth-trash-2" iconSize="14" iconColor="#F87171"/></graphic>
            </Button>

            <Button onAction="#handleConfirm" text="Confirm &amp; Save" prefWidth="200" styleClass="success" prefHeight="55">
                <graphic><FontIcon iconLiteral="fth-check-circle" iconSize="18" iconColor="#34D399"/></graphic>
            </Button>
        </VBox>
    </right>
</BorderPane>