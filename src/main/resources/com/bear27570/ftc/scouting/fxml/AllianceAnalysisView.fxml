<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<SplitPane dividerPositions="0.60" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bear27570.ftc.scouting.controllers.AllianceAnalysisController" prefHeight="750" prefWidth="1300">

    <VBox spacing="25" styleClass="mac-card">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="Alliance Partner Analysis" styleClass="title-3"/>

        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="panel-inner">
            <Label text="Target Main Team:" styleClass="text-muted, text-bold"/>
            <TextField fx:id="mainTeamField" promptText="Team #" prefWidth="160"/>
            <Button text="Analyze Partners" onAction="#handleAnalyze" styleClass="button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="mainTeamStatsLabel" text="Waiting for input..." styleClass="text-accent, text-bold"/>
        </HBox>

        <TableView fx:id="analysisTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="partnerCol" text="Partner" prefWidth="100"/>
                <TableColumn fx:id="totalEffCol" text="Proj. Score" prefWidth="120"/>
                <TableColumn fx:id="combinedAccCol" text="Accuracy" prefWidth="120"/>
                <TableColumn fx:id="stabilityCol" text="Stability" prefWidth="120"/>
                <TableColumn fx:id="styleCol" text="Analysis Note" prefWidth="300"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>
    </VBox>

    <VBox spacing="20" styleClass="mac-card">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
        <Label text="AI Studio Assistant" styleClass="title-3"/>
        <Label text="Markdown supported. Press Enter to send, Shift+Enter for new line." styleClass="text-muted"/>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <PasswordField fx:id="apiKeyField" promptText="Enter Gemini API Key..." HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="modelComboBox" prefWidth="180"/>
            <Button text="Save Key" onAction="#handleSaveApiKey" styleClass="accent">
                <graphic><FontIcon iconLiteral="fth-key" iconSize="16" iconColor="#18181B"/></graphic>
            </Button>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="panel-inner" style="-fx-background-color: transparent;">
            <CheckBox fx:id="useProxyCheck" text="HTTP Proxy"/>
            <TextField fx:id="proxyHostField" promptText="Host (127.0.0.1)" prefWidth="150"/>
            <TextField fx:id="proxyPortField" promptText="Port" prefWidth="100"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Test" onAction="#handleCheckConnection" styleClass="button"/>
        </HBox>

        <WebView fx:id="chatWebView" VBox.vgrow="ALWAYS" prefHeight="400" />

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Edit Last" onAction="#handleEditLastPrompt" styleClass="button-small">
                <graphic><FontIcon iconLiteral="fth-edit-2" iconSize="14"/></graphic>
            </Button>
            <Button text="Regenerate" onAction="#handleRegenerate" styleClass="button-small">
                <graphic><FontIcon iconLiteral="fth-refresh-cw" iconSize="14"/></graphic>
            </Button>
            <Button text="Clear Chat" onAction="#handleClearChat" styleClass="button-small, danger">
                <graphic><FontIcon iconLiteral="fth-trash-2" iconSize="14"/></graphic>
            </Button>
        </HBox>

        <HBox spacing="15" alignment="BOTTOM_LEFT">
            <TextArea fx:id="chatInputField" promptText="Ask AI about scouting data..." wrapText="true" prefRowCount="2" HBox.hgrow="ALWAYS"/>
            <Button text="Send" onAction="#handleSendChat" styleClass="accent" prefWidth="90" prefHeight="50">
                <graphic><FontIcon iconLiteral="fth-send" iconSize="16" iconColor="#18181B"/></graphic>
            </Button>
        </HBox>
    </VBox>
</SplitPane>